{
  "name": "TagTuner write tool",
  "description": "Get informations from Spotify current tab and send it to Home assistant tag tuner device",
  "version": "1.0",
  "manifest_version": 3,
  "icons": {
    "16": "tagtuner-128.png",
    "48": "tagtuner-128.png",
    "128": "tagtuner-128.png"
  },
  "action": {
    "default_icon": "tagtuner-128.png"
  },
  "background" : {
    "service_worker": "tagtuner.js",
    "type": "module"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "tabs",
    "scripting",
    "storage"
  ]
}
